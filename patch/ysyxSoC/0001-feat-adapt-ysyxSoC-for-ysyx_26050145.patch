 class ps2Chisel extends Module {
   val io = IO(new PS2CtrlIO)
+
+  val addr_base = "h10011000".U(32.W)
+  val addr_end = "h10011007".U(32.W)
+  def addrInRange(addr: UInt): Bool = addr >= addr_base && addr <= addr_end
