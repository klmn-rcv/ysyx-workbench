+    dout := MuxLookup(counter - rd_data_begin, rd_data(3,0))(Seq(
+      0.U -> rd_data(7,4),
+      1.U -> rd_data(3,0),
+      2.U -> rd_data(15,12),
+      3.U -> rd_data(11,8),
+      4.U -> rd_data(23,20),
+      5.U -> rd_data(19,16),
+      6.U -> rd_data(31,28),
+      7.U -> rd_data(27,24)
+    ))
+  }
 }
 
